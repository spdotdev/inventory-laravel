{
    "comment": "Canonical machine-readable manifest of the Inventory MCP tool surface. 'scope' is 'admin' (static admin-token auth, mirrored 1:1 by the EMBEDDED HTTP server in this repo, src/Mcp/, wire names kebab-case with a -tool suffix, e.g. list-users-tool) or 'household' (personal Sanctum-token auth, standalone stdio server only — the embedded server has no per-user auth context to run these against). The STANDALONE stdio server (https://github.com/spdotdev/inventory-mcp) implements both scopes, wire names snake_case, e.g. list_users. 'key' is the normalized logical name: strip the -tool suffix, kebab -> snake. Guards: tests/Feature/McpToolManifestTest.php (this repo, admin-scope tools only) and the conformance test in inventory-mcp CI (all tools). Change this file and both guards together when the surface grows.",
    "version": 2,
    "tools": [
        {
            "key": "list_users",
            "scope": "admin",
            "destructive": false,
            "params": []
        },
        {
            "key": "search_users",
            "scope": "admin",
            "destructive": false,
            "params": [
                { "name": "q", "type": "string", "required": true }
            ]
        },
        {
            "key": "get_user",
            "scope": "admin",
            "destructive": false,
            "params": [
                { "name": "id", "type": "integer", "required": true }
            ]
        },
        {
            "key": "delete_user",
            "scope": "admin",
            "destructive": true,
            "params": [
                { "name": "id", "type": "integer", "required": true }
            ]
        },
        {
            "key": "list_households",
            "scope": "admin",
            "destructive": false,
            "params": []
        },
        {
            "key": "get_household",
            "scope": "admin",
            "destructive": false,
            "params": [
                { "name": "id", "type": "integer", "required": true }
            ]
        },
        {
            "key": "delete_household",
            "scope": "admin",
            "destructive": true,
            "params": [
                { "name": "id", "type": "integer", "required": true }
            ]
        },
        {
            "key": "list_my_households",
            "scope": "household",
            "destructive": false,
            "params": []
        },
        {
            "key": "list_locations",
            "scope": "household",
            "destructive": false,
            "params": [
                { "name": "household_id", "type": "integer", "required": true }
            ]
        },
        {
            "key": "get_location",
            "scope": "household",
            "destructive": false,
            "params": [
                { "name": "household_id", "type": "integer", "required": true },
                { "name": "location_id", "type": "integer", "required": true }
            ]
        },
        {
            "key": "create_location",
            "scope": "household",
            "destructive": false,
            "params": [
                { "name": "household_id", "type": "integer", "required": true },
                { "name": "name", "type": "string", "required": true },
                { "name": "type", "type": "string", "required": true }
            ]
        },
        {
            "key": "update_location",
            "scope": "household",
            "destructive": false,
            "params": [
                { "name": "household_id", "type": "integer", "required": true },
                { "name": "location_id", "type": "integer", "required": true },
                { "name": "name", "type": "string", "required": false },
                { "name": "type", "type": "string", "required": false }
            ]
        },
        {
            "key": "delete_location",
            "scope": "household",
            "destructive": true,
            "params": [
                { "name": "household_id", "type": "integer", "required": true },
                { "name": "location_id", "type": "integer", "required": true },
                { "name": "strategy", "type": "string", "required": false },
                { "name": "target_location_id", "type": "integer", "required": false },
                { "name": "deletion_batch_id", "type": "string", "required": false }
            ]
        }
    ]
}
